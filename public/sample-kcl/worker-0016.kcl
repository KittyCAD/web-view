profile002 = startProfile(sketch002, at = [-0.535, 0.2])
  |> line(end = [1.07, 0])
  |> line(end = [0, 0.244])
  |> line(end = [-1.07, 0])
  |> close()
extrude002 = extrude(profile002, length = 2.79)
  |> appearance(color="#FFFFFF")

sketch003 = startSketchOn(XY)
profile003 = startProfile(sketch003, at = [-0.268, -0.133])
  |> line(end = [0.535, 0])
  |> line(end = [0, 0.266])
  |> line(end = [-0.535, 0])

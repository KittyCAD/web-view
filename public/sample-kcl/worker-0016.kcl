sketch001 = startSketchOn(XY)
profile001 = startProfile(sketch001, at = [-1.115, -0.555])
  |> line(end = [2.23, 0])
  |> line(end = [0, 1.11])
  |> line(end = [-2.23, 0])
  |> close()
extrude001 = extrude(profile001, length = 2.44)
  |> appearance(color="#FF8A3D")


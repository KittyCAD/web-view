sketch001 = startSketchOn(XY)
profile001 = startProfile(sketch001, at = [-0.675, -0.555])
  |> line(end = [1.35, 0])
  |> line(end = [0, 1.11])
  |> line(end = [-1.35, 0])
  |> close()
extrude001 = extrude(profile001, length = 1.54)
  |> appearance(color="#94A3B8")


  |> line(end = [0.648, 0])
  |> line(end = [0, 0.244])
  |> line(end = [-0.648, 0])
  |> close()
extrude002 = extrude(profile002, length = 1.89)
  |> appearance(color="#FFFFFF")

sketch003 = startSketchOn(XY)
profile003 = startProfile(sketch003, at = [-0.162, -0.133])
  |> line(end = [0.324, 0])

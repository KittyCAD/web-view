sketch001 = startSketchOn(XY)
profile001 = startProfile(sketch001, at = [-1.225, -0.555])
  |> line(end = [2.45, 0])
  |> line(end = [0, 1.11])
  |> line(end = [-2.45, 0])
  |> close()
extrude001 = extrude(profile001, length = 1.99)
  |> appearance(color="#00A3FF")


  |> line(end = [1.176, 0])
  |> line(end = [0, 0.209])
  |> line(end = [-1.176, 0])
  |> close()
extrude002 = extrude(profile002, length = 4.5)
  |> appearance(color="#FFFFFF")

sketch003 = startSketchOn(XY)

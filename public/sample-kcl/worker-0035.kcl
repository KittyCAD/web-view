sketch001 = startSketchOn(XY)
profile001 = startProfile(sketch001, at = [-1.225, -0.475])
  |> line(end = [2.45, 0])
  |> line(end = [0, 0.95])
  |> line(end = [-2.45, 0])
  |> close()
extrude001 = extrude(profile001, length = 4.15)
  |> appearance(color="#00A3FF")


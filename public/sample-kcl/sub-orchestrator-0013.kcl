profile002 = startProfile(sketch002, at = [-1.505, -1.08])
  |> line(end = [0.82, 0])
  |> line(end = [0, 2.138])
  |> line(end = [-0.82, 0])
  |> close()
extrude002 = extrude(profile002, length = 2.24)
  |> appearance(color="#F8FAFC")

sketch003 = startSketchOn(XY)
profile003 = startProfile(sketch003, at = [0.955, -0.81])
  |> line(end = [1.1, 0])
  |> line(end = [0, 1.62])

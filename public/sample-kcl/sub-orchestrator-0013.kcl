sketch001 = startSketchOn(XY)
profile001 = startProfile(sketch001, at = [-3.01, -1.62])
  |> line(end = [6.02, 0])
  |> line(end = [0, 3.24])
  |> line(end = [-6.02, 0])
  |> close()
extrude001 = extrude(profile001, length = 0.69)
  |> appearance(color="#00A3FF")


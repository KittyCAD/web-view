  |> line(end = [1.176, 0])
  |> line(end = [0, 0.279])
  |> line(end = [-1.176, 0])
  |> close()
extrude002 = extrude(profile002, length = 2.88)
  |> appearance(color="#FFFFFF")

sketch003 = startSketchOn(XY)

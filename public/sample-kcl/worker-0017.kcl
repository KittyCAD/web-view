sketch001 = startSketchOn(XY)
profile001 = startProfile(sketch001, at = [-1.225, -0.635])
  |> line(end = [2.45, 0])
  |> line(end = [0, 1.27])
  |> line(end = [-2.45, 0])
  |> close()
extrude001 = extrude(profile001, length = 2.53)
  |> appearance(color="#2DD4BF")


sketch001 = startSketchOn(XY)
profile001 = startProfile(sketch001, at = [-2.17, -1.14])
  |> line(end = [4.34, 0])
  |> line(end = [0, 2.28])
  |> line(end = [-4.34, 0])
  |> close()
extrude001 = extrude(profile001, length = 0.69)
  |> appearance(color="#00A3FF")

